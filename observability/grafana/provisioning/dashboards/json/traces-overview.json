{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "RED metrics — project: $project",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Span rate by service (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{project=~\"$project\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by span (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, span_name, service_name) (rate(traces_spanmetrics_latency_bucket{project=~\"$project\"}[5m])))",
          "legendFormat": "{{service_name}} — {{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Error rate by service (errors/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{project=~\"$project\", status_code=\"STATUS_CODE_ERROR\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Top 10 spans by call rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "topk(10, sum by (span_name, service_name) (rate(traces_spanmetrics_calls_total{project=~\"$project\"}[5m])))",
          "legendFormat": "{{service_name}} — {{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "row",
      "title": "Recent traces",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "title": "Last traces (click row to view)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "targets": [
        {
          "queryType": "traceqlSearch",
          "limit": 50,
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "operator": "=~",
              "scope": "resource"
            }
          ],
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "type": "row",
      "title": "Service graph",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "nodeGraph",
      "title": "Service graph (from spans)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 29 },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (client, server) (rate(traces_service_graph_request_total{project=~\"$project\"}[5m]))",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["traces", "tempo"],
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(traces_spanmetrics_calls_total, project)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Traces Overview",
  "uid": "traces-overview",
  "version": 1,
  "weekStart": ""
}
