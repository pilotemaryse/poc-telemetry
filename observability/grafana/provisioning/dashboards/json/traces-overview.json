{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "RED metrics — project: $project",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Span rate by service (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{project=~\"$project\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by span (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, span_name, service_name) (rate(traces_spanmetrics_latency_bucket{project=~\"$project\"}[5m]))) or histogram_quantile(0.95, sum by (le, span_name, service_name) (rate(traces_spanmetrics_duration_seconds_bucket{project=~\"$project\"}[5m])))",
          "legendFormat": "{{service_name}} — {{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Error rate by service (errors/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{project=~\"$project\", status_code=~\"STATUS_CODE_ERROR|ERROR\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Top 10 spans by call rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "topk(10, sum by (span_name, service_name) (rate(traces_spanmetrics_calls_total{project=~\"$project\"}[5m])))",
          "legendFormat": "{{service_name}} — {{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "row",
      "title": "Latency distribution",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 103,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "heatmap",
      "title": "Trace latency heatmap (all spans)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "targets": [
        {
          "expr": "sum by (le) (increase(traces_spanmetrics_latency_bucket{project=~\"$project\"}[$__rate_interval])) or sum by (le) (increase(traces_spanmetrics_duration_seconds_bucket{project=~\"$project\"}[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": { "scheme": "Spectral", "mode": "scheme", "steps": 64, "reverse": true },
        "yAxis": { "unit": "s", "decimals": 2 },
        "tooltip": { "show": true, "yHistogram": true },
        "legend": { "show": true }
      }
    },
    {
      "type": "row",
      "title": "Recent traces",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "title": "Last traces (click traceID to open waterfall)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "id": 5,
      "targets": [
        {
          "queryType": "traceqlSearch",
          "limit": 50,
          "tableType": "traces",
          "filters": [
            {
              "id": "min-duration",
              "tag": "duration",
              "operator": ">",
              "value": "1ns",
              "valueType": "duration"
            }
          ],
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "type": "row",
      "title": "Service graph",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "nodeGraph",
      "title": "Service graph (from spans)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 39 },
      "id": 6,
      "targets": [
        {
          "queryType": "serviceMap",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["traces", "tempo"],
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(traces_spanmetrics_calls_total, project)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Traces Overview",
  "uid": "traces-overview",
  "version": 2,
  "weekStart": ""
}
